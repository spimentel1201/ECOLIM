<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light_gray">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_green"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Reportes de Recolección"
        app:titleTextColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reportsDateFilter"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectDateRange"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reportsSelectDate"
            app:icon="@drawable/ic_reports" />

        <TextView
            android:id="@+id/tvSelectedDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reportsRange"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reportsWasteType"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/reportTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportExcel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/buttonExportToExcel"
            android:backgroundTint="@color/primary_green"
            app:icon="@drawable/ic_reports"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/textInfoReport"
            android:textAlignment="center"
            android:textSize="12sp"
            android:alpha="0.7"/>

    </LinearLayout>

</RelativeLayout>
